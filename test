// ═══════════════════════════════════════
// AUTO LANGUAGE DETECTION
// ═══════════════════════════════════════

function detectLanguage() {
    // 1. Check saved preference first
    const saved = localStorage.getItem('rozrashi_lang');
    if (saved && ['hi', 'mr'].includes(saved)) return saved;

    // 2. Check browser language
    const browserLang = navigator.language || navigator.userLanguage || 'hi';

    if (browserLang.startsWith('mr')) return 'mr';
    if (browserLang.startsWith('hi')) return 'hi';

    // 3. Default to Hindi
    return 'hi';
}

// ═══════════════════════════════════════
// LANGUAGE MANAGER
// ═══════════════════════════════════════

let currentLang = detectLanguage();

function setLanguage(lang) {
    currentLang = lang;
    localStorage.setItem('rozrashi_lang', lang);
    updateLanguageButtons();
    updateAllUI();
    loadRashiGrid('rashi-grid');
    loadHomeStatusPreview();
}

function L(key) {
    return LANG_UI[currentLang][key] || LANG_UI['hi'][key] || key;
}

function getRashiName(id) {
    return RASHI_NAMES[currentLang][id] || RASHI_NAMES['hi'][id];
}

function updateLanguageButtons() {
    document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    const activeBtn = document.getElementById('lang-' + currentLang);
    if (activeBtn) activeBtn.classList.add('active');
}

function updateAllUI() {
    // Header date
    updateHeaderDate();

    // Welcome card
    const welcomeTitle = document.getElementById('welcome-title');
    const welcomeSub = document.getElementById('welcome-sub');
    if (welcomeTitle) welcomeTitle.textContent = L('welcome_title');
    if (welcomeSub) welcomeSub.textContent = L('welcome_sub');

    // Section titles
    const selectRashiTitle = document.getElementById('select-rashi-title');
    const todaysStatusTitle = document.getElementById('todays-status-title');
    if (selectRashiTitle) selectRashiTitle.textContent = L('select_rashi');
    if (todaysStatusTitle) todaysStatusTitle.textContent = L('todays_status');

    // Nav labels
    const navLabels = {
        'nav-label-home': L('nav_home'),
        'nav-label-rashifal': L('nav_rashifal'),
        'nav-label-status': L('nav_status'),
        'nav-label-panchang': L('nav_panchang'),
        'nav-label-kundali': L('nav_kundali'),
    };
    Object.entries(navLabels).forEach(([id, text]) => {
        const el = document.getElementById(id);
        if (el) el.textContent = text;
    });

    // Status tabs
    const tabGoodMorning = document.getElementById('tab-good-morning');
    const tabBhakti = document.getElementById('tab-bhakti');
    if (tabGoodMorning) tabGoodMorning.innerHTML = L('tab_good_morning');
    if (tabBhakti) tabBhakti.innerHTML = L('tab_bhakti');

    // Loading texts
    document.querySelectorAll('.loading').forEach(el => {
        if (el.dataset.type === 'rashi') el.textContent = L('loading_rashi');
        else if (el.dataset.type === 'status') el.textContent = L('loading_status');
        else el.textContent = L('loading_general');
    });
}

function updateHeaderDate() {
    const now = new Date();
    const dayName = L('days')[now.getDay()];
    const monthName = L('months')[now.getMonth()];
    const dateStr = `${dayName}, ${now.getDate()} ${monthName}`;
    const dateEl = document.getElementById('today-date');
    if (dateEl) dateEl.textContent = dateStr;
}

function getStatusContent(category) {
    if (currentLang === 'mr') {
        return STATUS_MARATHI[category] || [];
    }
    // Hindi content comes from API (app.py)
    return null; // will use API
}

// Initialize language on page load
document.addEventListener('DOMContentLoaded', function() {
    updateLanguageButtons();
    updateAllUI();
});